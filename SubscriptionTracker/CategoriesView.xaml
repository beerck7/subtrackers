<UserControl x:Class="SubscriptionTracker.CategoriesView"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

        <Grid Margin="20,20,20,90">

            <StackPanel MaxWidth="1200" HorizontalAlignment="Stretch">



                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">

                    <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource PrimaryBrush}" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>

                    <TextBlock Text="SubTrack" Foreground="{DynamicResource TextPrimary}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>

                </StackPanel>



                <StackPanel Margin="0,0,0,30">

                    <TextBlock Text="Kategorie" Foreground="{DynamicResource TextPrimary}" FontSize="36" FontWeight="Bold"/>

                    <TextBlock Text="Organizuj i śledź budżet" Foreground="{DynamicResource TextSecondary}" FontSize="14" Margin="0,5,0,0"/>

                </StackPanel>



                <WrapPanel Margin="0,0,0,30">

                    <TextBox Width="300" Height="45" Margin="0,0,15,15"

                             Style="{StaticResource ModernTextBox}"

                             Tag="Wpisz nazwę kategorii..."

                             Text="{Binding NewCategoryName, UpdateSourceTrigger=PropertyChanged}"

                             ToolTip="Nazwa nowej kategorii" />

                    <Button Content="Dodaj kategorię" Width="140" Height="45" Margin="0,0,0,15"

                            Style="{StaticResource PrimaryButton}"

                            Command="{Binding AddCategoryCommand}" />

                </WrapPanel>



                <!-- KATEGORIE LISTA -->

                <ItemsControl ItemsSource="{Binding Categories}">

                    <ItemsControl.ItemsPanel>

                        <ItemsPanelTemplate>

                            <WrapPanel />

                        </ItemsPanelTemplate>

                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>

                        <DataTemplate>

                            <Border x:Name="itemBorder" Width="400" Margin="8,8,16,16">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#25252D"/>
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <ScaleTransform ScaleX="1.02" ScaleY="1.02" CenterX="0.5" CenterY="0.5"/>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>

                                    <Grid.ColumnDefinitions>

                                        <ColumnDefinition Width="Auto"/>

                                        <ColumnDefinition Width="*"/>

                                        <ColumnDefinition Width="Auto"/>

                                        <ColumnDefinition Width="Auto"/>

                                    </Grid.ColumnDefinitions>



                                    <Ellipse Width="16" Height="16" Fill="{Binding Color}" VerticalAlignment="Center" Margin="0,0,20,0" />



                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">

                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimary}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4"/>

                                        <TextBlock Text="{Binding SubscriptionsCountText}" Foreground="{DynamicResource TextSecondary}" FontSize="13"/>

                                    </StackPanel>



                                    <TextBlock Grid.Column="2" 

                                               Text="{Binding FormattedTotalCost}" 

                                               Foreground="{DynamicResource TextPrimary}" 

                                               FontSize="22" 

                                               FontWeight="Bold" 

                                               VerticalAlignment="Center"

                                               Margin="0,0,15,0"/>



                                    <Button Grid.Column="3" Command="{Binding DataContext.DeleteCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Usuń" VerticalAlignment="Center">

                                        <Button.Template>

                                            <ControlTemplate TargetType="Button">

                                                <TextBlock x:Name="btnTxt" Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource TextSecondary}" FontSize="14" VerticalAlignment="Center"/>

                                                <ControlTemplate.Triggers>

                                                    <Trigger Property="IsMouseOver" Value="True">

                                                        <Setter TargetName="btnTxt" Property="Foreground" Value="{StaticResource DangerBrush}"/>

                                                    </Trigger>

                                                </ControlTemplate.Triggers>

                                            </ControlTemplate>

                                        </Button.Template>

                                    </Button>

                                </Grid>

                            </Border>

                        </DataTemplate>

                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </StackPanel>

        </Grid>

    </ScrollViewer>

</UserControl>


