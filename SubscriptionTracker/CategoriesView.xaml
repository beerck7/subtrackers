<UserControl x:Class="SubscriptionTracker.CategoriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="50,40,50,0">
        <StackPanel>
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" Foreground="#3b82f6" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="SubTrack" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Margin="0,0,0,30">
                <TextBlock Text="Kategorie" Foreground="White" FontSize="32" FontWeight="SemiBold"/>
                <TextBlock Text="Organizuj i śledź budżet" Foreground="#8A8A93" FontSize="13" Margin="0,5,0,0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                <TextBox Width="250" Height="40" Padding="10,0" Margin="0,0,10,0"
                         Background="#1E1E24" Foreground="White" BorderBrush="#2A2A35" BorderThickness="1"
                         VerticalContentAlignment="Center"
                         Text="{Binding NewCategoryName, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Nazwa nowej kategorii" />
                <Button Content="Dodaj kategorię" Width="120" Height="40"
                        Background="#3b82f6" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Command="{Binding AddCategoryCommand}" />
            </StackPanel>

            <!-- KATEGORIE LISTA -->
            <ItemsControl ItemsSource="{Binding Categories}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#1E1E24" CornerRadius="12" Padding="25" Margin="5" BorderBrush="#2A2A35" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <Ellipse Width="12" Height="12" Fill="{Binding Color}" VerticalAlignment="Center" Margin="0,0,15,0" />
                                
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding SubscriptionsCountText}" Foreground="#8A8A93" FontSize="12"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2" 
                                           Text="{Binding FormattedTotalCost}" 
                                           Foreground="White" 
                                           FontSize="18" 
                                           FontWeight="Bold" 
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</UserControl>
