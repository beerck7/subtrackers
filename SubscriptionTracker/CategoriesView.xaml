<UserControl x:Class="SubscriptionTracker.CategoriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="50,40,50,0">
        <StackPanel>
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" Foreground="#3b82f6" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="SubTrack" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Margin="0,0,0,30">
                <TextBlock Text="Kategorie" Foreground="White" FontSize="32" FontWeight="SemiBold"/>
                <TextBlock Text="Organizuj i śledź budżet" Foreground="#8A8A93" FontSize="13" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- KATEGORIE KARTY W GRIDZIE 2x2 -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- KATEGORIA 1: Oprogramowanie -->
                <Border Grid.Row="0" Grid.Column="0" Background="#1E1E24" CornerRadius="12" Padding="25" BorderBrush="#2A2A35" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <Ellipse Width="12" Height="12" Fill="#3b82f6" VerticalAlignment="Center" Margin="0,0,15,0" />
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Oprogramowanie" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="8 Usług" Foreground="#8A8A93" FontSize="12"/>
                        </StackPanel>

                        <TextBlock Grid.Column="2" 
                                   Text="850,00 PLN" 
                                   Foreground="White" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- KATEGORIA 2: Streaming -->
                <Border Grid.Row="0" Grid.Column="2" Background="#1E1E24" CornerRadius="12" Padding="25" BorderBrush="#2A2A35" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <Ellipse Width="12" Height="12" Fill="#22c55e" VerticalAlignment="Center" Margin="0,0,15,0" />
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Streaming" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="5 Usług" Foreground="#8A8A93" FontSize="12"/>
                        </StackPanel>

                        <TextBlock Grid.Column="2" 
                                   Text="180,00 PLN" 
                                   Foreground="White" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- KATEGORIA 3: Gry -->
                <Border Grid.Row="2" Grid.Column="0" Background="#1E1E24" CornerRadius="12" Padding="25" BorderBrush="#2A2A35" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <Ellipse Width="12" Height="12" Fill="#eab308" VerticalAlignment="Center" Margin="0,0,15,0" />
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Gry" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="3 Usługi" Foreground="#8A8A93" FontSize="12"/>
                        </StackPanel>

                        <TextBlock Grid.Column="2" 
                                   Text="240,00 PLN" 
                                   Foreground="White" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                
                <!-- KATEGORIA 4: Inne -->
                <Border Grid.Row="2" Grid.Column="2" Background="#1E1E24" CornerRadius="12" Padding="25" BorderBrush="#2A2A35" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <Ellipse Width="12" Height="12" Fill="#a855f7" VerticalAlignment="Center" Margin="0,0,15,0" />
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Inne" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="12 Usług" Foreground="#8A8A93" FontSize="12"/>
                        </StackPanel>

                        <TextBlock Grid.Column="2" 
                                   Text="575,90 PLN" 
                                   Foreground="White" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
