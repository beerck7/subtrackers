<UserControl x:Class="SubscriptionTracker.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#1B1B2B" CornerRadius="15" Padding="20">
        <StackPanel>
            <!-- HEADER -->
            <TextBlock Text="SubTrack" Foreground="White" FontSize="16"/>
            <TextBlock Text="Podsumowanie"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,10,0,0"/>

            <!-- KARTY -->
            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- KARTA 1 -->
                <Border Background="#24243A" CornerRadius="10" Padding="20" Margin="10">
                    <StackPanel>
                        <TextBlock Text="Miesięczne koszty" Foreground="Gray"/>
                        <TextBlock Text="1845,90 PLN"
                                   Foreground="White"
                                   FontSize="22"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- KARTA 2 -->
                <Border Background="#24243A" CornerRadius="10" Padding="20" Margin="10" Grid.Column="1">
                    <StackPanel>
                        <TextBlock Text="Aktywne subskrypcje" Foreground="Gray"/>
                        <TextBlock Text="28 usług"
                                   Foreground="White"
                                   FontSize="22"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- LISTA -->
            <Border Background="#24243A" CornerRadius="10" Padding="15" Margin="10">
                <StackPanel>
                    <TextBlock Text="Nadchodzące płatności" Foreground="White"/>

                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Text="Netflix - 60 PLN" Foreground="LightGray"/>
                        <TextBlock Text="Spotify - 19,99 PLN" Foreground="LightGray"/>
                        <TextBlock Text="Adobe - 249 PLN" Foreground="LightGray"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
