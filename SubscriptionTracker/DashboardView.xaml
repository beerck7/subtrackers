<UserControl x:Class="SubscriptionTracker.DashboardView"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             Background="Transparent">

    <UserControl.Resources>



        <Style x:Key="SegmentRadioButton" TargetType="RadioButton">

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="RadioButton">

                        <Border x:Name="border" CornerRadius="12" Padding="12,6" Background="Transparent">

                            <ContentPresenter x:Name="contentPresenter" HorizontalAlignment="Center" VerticalAlignment="Center" TextBlock.Foreground="{DynamicResource TextSecondary}" TextBlock.FontWeight="SemiBold" TextBlock.FontSize="11"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsChecked" Value="True">

                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryBrush}"/>

                                <Setter TargetName="contentPresenter" Property="TextBlock.Foreground" Value="White"/>

                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">

                                <Setter TargetName="border" Property="Cursor" Value="Hand"/>

                            </Trigger>

                            <MultiTrigger>

                                <MultiTrigger.Conditions>

                                    <Condition Property="IsMouseOver" Value="True"/>

                                    <Condition Property="IsChecked" Value="False"/>

                                </MultiTrigger.Conditions>

                                <Setter TargetName="border" Property="Background" Value="#252530"/>

                                <Setter TargetName="contentPresenter" Property="TextBlock.Foreground" Value="{DynamicResource TextPrimary}"/>

                            </MultiTrigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

    </UserControl.Resources>



    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">



        <Grid Margin="20,20,20,90">



            <StackPanel MaxWidth="1600" HorizontalAlignment="Stretch">















                <TextBlock Text="Podsumowanie" Foreground="{DynamicResource TextPrimary}" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>



                <TextBlock Text="{Binding TodayDateText}" Foreground="{DynamicResource TextSecondary}" FontSize="14" Margin="0,5,0,35" HorizontalAlignment="Center"/>











                <Grid Margin="0,0,0,10">



                    <Grid.ColumnDefinitions>



                        <ColumnDefinition Width="*"/>



                        <ColumnDefinition Width="*"/>



                    </Grid.ColumnDefinitions>







                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,20">



                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">



                            <Border Width="50" Height="50" CornerRadius="12" Background="#161b26" VerticalAlignment="Center" Margin="0,0,20,0">



                                <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource PrimaryBrush}" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>



                            </Border>



                            <StackPanel VerticalAlignment="Center">



                                <TextBlock Text="Miesięczne koszty" Foreground="{DynamicResource TextSecondary}" FontSize="14" Margin="0,0,0,4"/>



                                <TextBlock Text="{Binding MonthlyCostsText}" Foreground="{DynamicResource TextPrimary}" FontSize="32" FontWeight="Bold" Margin="0,0,0,4"/>



                                <TextBlock Text="Suma kosztów cyklicznych" Foreground="{StaticResource SuccessBrush}" FontSize="13"/>



                            </StackPanel>



                        </StackPanel>



                    </Border>







                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="10,0,0,20">



                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">



                            <Border Width="50" Height="50" CornerRadius="12" Background="#1a1c23" VerticalAlignment="Center" Margin="0,0,20,0">



                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource PrimaryBrush}" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>



                            </Border>



                            <StackPanel VerticalAlignment="Center">



                                <TextBlock Text="Aktywne subskrypcje" Foreground="{DynamicResource TextSecondary}" FontSize="14" Margin="0,0,0,4"/>



                                <TextBlock Text="{Binding ActiveSubscriptionsCountText}" Foreground="{DynamicResource TextPrimary}" FontSize="32" FontWeight="Bold" Margin="0,0,0,4"/>



                                <TextBlock Text="{Binding NewSubscriptionsThisMonthText}" Foreground="{DynamicResource TextSecondary}" FontSize="13"/>



                            </StackPanel>



                        </StackPanel>



                    </Border>



                </Grid>











                <Grid Margin="0,25,0,0">



                    <Grid.ColumnDefinitions>



                        <ColumnDefinition Width="323*"/>



                        <ColumnDefinition Width="317*"/>



                    </Grid.ColumnDefinitions>







                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,20">



                        <StackPanel>



                            <TextBlock Text="Nadchodzące płatności" Foreground="{DynamicResource TextPrimary}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,25"/>







                            <ItemsControl ItemsSource="{Binding UpcomingPayments}">



                                <ItemsControl.ItemTemplate>



                                    <DataTemplate>



                                        <StackPanel>
                                             <Grid Margin="0,0,0,15">
                                                 <Grid.ColumnDefinitions>
                                                     <ColumnDefinition Width="Auto"/>
                                                     <ColumnDefinition Width="2*"/>
                                                     <ColumnDefinition Width="1*"/>
                                                     <ColumnDefinition Width="Auto"/>
                                                 </Grid.ColumnDefinitions>

                                                 <Border Width="45" Height="45" CornerRadius="10" Background="{Binding IconColor}" Margin="0,0,15,0">
                                                     <TextBlock Text="{Binding Initials}" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                 </Border>

                                                 <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,10,0">
                                                     <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold" FontSize="15" TextTrimming="CharacterEllipsis"/>
                                                     <TextBlock Text="{Binding NextPaymentDateFormatted}" Foreground="{DynamicResource TextSecondary}" FontSize="13"/>
                                                 </StackPanel>

                                                 <TextBlock Grid.Column="2" Text="{Binding Category}" Foreground="{DynamicResource TextSecondary}" FontSize="14" VerticalAlignment="Center" Margin="10,0,20,0" TextTrimming="CharacterEllipsis"/>

                                                 <TextBlock Grid.Column="3" Text="{Binding FormattedPrice}" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/>
                                             </Grid>

                                            <Rectangle Height="1" Fill="{DynamicResource CardBorder}" Margin="0,5,0,15"/>



                                        </StackPanel>



                                    </DataTemplate>



                                </ItemsControl.ItemTemplate>



                            </ItemsControl>







                            <TextBlock Text="Brak nadchodzących płatności" Foreground="{DynamicResource TextSecondary}" FontSize="14" HorizontalAlignment="Center" Margin="0,20,0,20">



                                <TextBlock.Style>



                                    <Style TargetType="TextBlock">



                                        <Setter Property="Visibility" Value="Collapsed"/>



                                        <Style.Triggers>



                                            <DataTrigger Binding="{Binding UpcomingPayments.Count}" Value="0">



                                                <Setter Property="Visibility" Value="Visible"/>



                                            </DataTrigger>



                                        </Style.Triggers>



                                    </Style>



                                </TextBlock.Style>



                            </TextBlock>



                        </StackPanel>



                    </Border>







                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="10,0,0,20">



                        <StackPanel>



                            <Grid Margin="0,0,0,30">

                                <Grid.ColumnDefinitions>

                                    <ColumnDefinition Width="*"/>

                                    <ColumnDefinition Width="Auto"/>

                                </Grid.ColumnDefinitions>



                                <TextBlock Text="Wydatki wg kategorii" Foreground="{DynamicResource TextPrimary}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>





                                <Border Grid.Column="1" Background="{DynamicResource InputBackground}" CornerRadius="15" Padding="3" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" VerticalAlignment="Center">

                                    <Grid>

                                        <Grid.ColumnDefinitions>

                                            <ColumnDefinition Width="Auto"/>

                                            <ColumnDefinition Width="Auto"/>

                                        </Grid.ColumnDefinitions>





                                        <RadioButton x:Name="BtnMonthly" Grid.Column="0" GroupName="PeriodGroup" IsChecked="True" Content="Miesięcznie" Style="{StaticResource SegmentRadioButton}"/>





                                        <RadioButton x:Name="BtnYearly" Grid.Column="1" GroupName="PeriodGroup" IsChecked="{Binding IsYearlyView}" Content="Rocznie" Style="{StaticResource SegmentRadioButton}"/>

                                    </Grid>

                                </Border>

                            </Grid>







                            <Grid Width="150" Height="150" HorizontalAlignment="Center">



                                <ItemsControl ItemsSource="{Binding CategoryExpenses}">

                                    <ItemsControl.ItemsPanel>

                                        <ItemsPanelTemplate>

                                            <Grid />

                                        </ItemsPanelTemplate>

                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>

                                        <DataTemplate>

                                            <Path Data="{Binding PathData}" 

                                                  Stroke="{Binding Color}" 

                                                  StrokeThickness="18" 

                                                  StrokeEndLineCap="Round" 

                                                  StrokeStartLineCap="Round"

                                                  ToolTip="{Binding FormattedCostWithPercentage}"/>

                                        </DataTemplate>

                                    </ItemsControl.ItemTemplate>

                                </ItemsControl>





                                <Ellipse Stroke="#1A1A22" StrokeThickness="18" Width="120" Height="120" IsHitTestVisible="False"/>





                                <Ellipse Fill="{DynamicResource CardBackground}" Width="98" Height="98" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>



                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">

                                    <TextBlock Text="{Binding ExpensePeriodLabel}" Foreground="{DynamicResource TextSecondary}" FontSize="11" HorizontalAlignment="Center"/>

                                    <TextBlock Text="{Binding MonthlyCostsText}" Foreground="{DynamicResource TextPrimary}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>

                                </StackPanel>

                            </Grid>







                            <ItemsControl ItemsSource="{Binding CategoryExpenses}" Margin="0,30,0,0">



                                <ItemsControl.ItemTemplate>



                                    <DataTemplate>



                                        <StackPanel Margin="0,0,0,12">



                                            <Grid>



                                                <Grid.ColumnDefinitions>



                                                    <ColumnDefinition Width="Auto"/>



                                                    <ColumnDefinition Width="*"/>



                                                    <ColumnDefinition Width="Auto"/>



                                                </Grid.ColumnDefinitions>



                                                <Ellipse Width="10" Height="10" Fill="{Binding Color}" VerticalAlignment="Center" Margin="0,0,10,0"/>



                                                <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{DynamicResource TextPrimary}" FontSize="13" FontWeight="SemiBold"/>



                                                <TextBlock Grid.Column="2" Text="{Binding FormattedCostWithPercentage}" Foreground="{DynamicResource TextSecondary}" FontSize="13" FontWeight="Bold"/>



                                            </Grid>



                                            <ProgressBar Height="4" Margin="0,6,0,0" Minimum="0" Maximum="100" Value="{Binding Percentage}" Foreground="{Binding Color}" Background="{DynamicResource InputBackground}" BorderThickness="0">



                                                <ProgressBar.Template>



                                                    <ControlTemplate TargetType="ProgressBar">



                                                        <Grid>



                                                            <Border Background="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}" CornerRadius="2"/>



                                                            <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" CornerRadius="2" HorizontalAlignment="Left"/>



                                                        </Grid>



                                                    </ControlTemplate>



                                                </ProgressBar.Template>



                                            </ProgressBar>



                                        </StackPanel>



                                    </DataTemplate>



                                </ItemsControl.ItemTemplate>



                            </ItemsControl>







                            <TextBlock Text="Brak danych do wyświetlenia" Foreground="{DynamicResource TextSecondary}" FontSize="14" HorizontalAlignment="Center" Margin="0,20,0,20">



                                <TextBlock.Style>



                                    <Style TargetType="TextBlock">



                                        <Setter Property="Visibility" Value="Collapsed"/>



                                        <Style.Triggers>



                                            <DataTrigger Binding="{Binding CategoryExpenses.Count}" Value="0">



                                                <Setter Property="Visibility" Value="Visible"/>



                                            </DataTrigger>



                                        </Style.Triggers>



                                    </Style>



                                </TextBlock.Style>



                            </TextBlock>



                        </StackPanel>



                    </Border>



                </Grid>







            </StackPanel>



        </Grid>



    </ScrollViewer>



</UserControl>




