<UserControl x:Class="SubscriptionTracker.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20,20,20,90">
            <StackPanel MaxWidth="1000" HorizontalAlignment="Center">
                
                <!-- HEADER -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource PrimaryBrush}" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="SubTrack" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                
                <TextBlock Text="Podsumowanie" Foreground="{StaticResource TextPrimary}" FontSize="36" FontWeight="Bold"/>
                <TextBlock Text="Dzisiejsza data: 29 marca 2026" Foreground="{StaticResource TextSecondary}" FontSize="14" Margin="0,5,0,35"/>

                <!-- TOP CARDS -->
                <WrapPanel Margin="0,0,0,10">

                    <!-- KOSZTY -->
                    <Border Style="{StaticResource CardStyle}" Width="350" Margin="0,0,20,20">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="50" Height="50" CornerRadius="12" Background="#161b26" VerticalAlignment="Center" Margin="0,0,20,0">
                                <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource PrimaryBrush}" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Miesięczne koszty" Foreground="{StaticResource TextSecondary}" FontSize="14" Margin="0,0,0,4"/>
                                <TextBlock Text="1845,90 PLN" Foreground="{StaticResource TextPrimary}" FontSize="32" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Text="-2.3% vs poprzedni miesiąc" Foreground="{StaticResource SuccessBrush}" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- SUBSKRYPCJE -->
                    <Border Style="{StaticResource CardStyle}" Width="350" Margin="0,0,20,20">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="50" Height="50" CornerRadius="12" Background="#1a1c23" VerticalAlignment="Center" Margin="0,0,20,0">
                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource PrimaryBrush}" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Aktywne subskrypcje" Foreground="{StaticResource TextSecondary}" FontSize="14" Margin="0,0,0,4"/>
                                <TextBlock Text="28 Usług" Foreground="{StaticResource TextPrimary}" FontSize="32" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Text="4 nowe w tym miesiącu" Foreground="{StaticResource TextSecondary}" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <!-- BOTTOM SECTION -->
                <WrapPanel Margin="0,25,0,0">

                    <!-- LISTA -->
                    <Border Style="{StaticResource CardStyle}" Width="500" Margin="0,0,20,20">
                        <StackPanel>
                            <TextBlock Text="Nadchodzące płatności" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,25"/>
                            
                            <!-- Item 1 -->
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="45" Height="45" CornerRadius="10" Background="#e50914" Margin="0,0,15,0">
                                    <TextBlock Text="N" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Netflix" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="15"/>
                                    <TextBlock Text="14 Maja" Foreground="{StaticResource TextSecondary}" FontSize="13"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="Streaming" Foreground="{StaticResource TextSecondary}" FontSize="14" VerticalAlignment="Center" Margin="0,0,30,0"/>
                                <TextBlock Grid.Column="3" Text="60,00 PLN" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/>
                            </Grid>

                            <Rectangle Height="1" Fill="{StaticResource CardBorder}" Margin="0,10,0,20"/>

                            <!-- Item 2 -->
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="45" Height="45" CornerRadius="10" Background="#ff0000" Margin="0,0,15,0">
                                    <TextBlock Text="A" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Adobe CC" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="15"/>
                                    <TextBlock Text="15 Maja" Foreground="{StaticResource TextSecondary}" FontSize="13"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="Oprogramowanie" Foreground="{StaticResource TextSecondary}" FontSize="14" VerticalAlignment="Center" Margin="0,0,30,0"/>
                                <TextBlock Grid.Column="3" Text="249,99 PLN" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/>
                            </Grid>

                            <Rectangle Height="1" Fill="{StaticResource CardBorder}" Margin="0,10,0,20"/>

                            <!-- Item 3 -->
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="45" Height="45" CornerRadius="10" Background="#1db954" Margin="0,0,15,0">
                                    <TextBlock Text="S" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Spotify" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="15"/>
                                    <TextBlock Text="18 Maja" Foreground="{StaticResource TextSecondary}" FontSize="13"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="Streaming" Foreground="{StaticResource TextSecondary}" FontSize="14" VerticalAlignment="Center" Margin="0,0,30,0"/>
                                <TextBlock Grid.Column="3" Text="19,99 PLN" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- WYKRES WIZUALIZACJA -->
                    <Border Style="{StaticResource CardStyle}" Width="350" Margin="0,0,20,20">
                        <StackPanel>
                            <TextBlock Text="Wydatki wg kategorii" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,40"/>
                            
                            <Grid Width="180" Height="180" HorizontalAlignment="Center">
                                <!-- Solid circle + slices to mimic a pie chart -->
                                <Ellipse Fill="{StaticResource PrimaryBrush}" Width="180" Height="180"/>
                                <Path Data="M 90,90 L 90,0 A 90,90 0 0,1 180,90 Z" Fill="#a855f7" />
                                <Path Data="M 90,90 L 180,90 A 90,90 0 0,1 90,180 Z" Fill="{StaticResource SuccessBrush}" />
                                <Path Data="M 90,90 L 90,180 A 90,90 0 0,1 0,90 Z" Fill="#eab308" />
                                <!-- Inner circle to make it a donut -->
                                <Ellipse Fill="{StaticResource CardBackground}" Width="120" Height="120" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="Wydatki" Foreground="{StaticResource TextSecondary}" FontSize="12" HorizontalAlignment="Center"/>
                                    <TextBlock Text="100%" Foreground="{StaticResource TextPrimary}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,40,0,0">
                                <Ellipse Width="10" Height="10" Fill="{StaticResource PrimaryBrush}" Margin="0,0,8,0"/>
                                <TextBlock Text="Programy" Foreground="{StaticResource TextPrimary}" FontSize="13" Margin="0,0,20,0"/>
                                
                                <Ellipse Width="10" Height="10" Fill="{StaticResource SuccessBrush}" Margin="0,0,8,0"/>
                                <TextBlock Text="Streaming" Foreground="{StaticResource TextPrimary}" FontSize="13" Margin="0,0,20,0"/>
                                
                                <Ellipse Width="10" Height="10" Fill="#eab308" Margin="0,0,8,0"/>
                                <TextBlock Text="Gry" Foreground="{StaticResource TextPrimary}" FontSize="13"/>
                            </StackPanel>

                        </StackPanel>
                    </Border>
                </WrapPanel>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
