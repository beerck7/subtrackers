<UserControl x:Class="SubscriptionTracker.SubscriptionsView"



             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"



             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"



             Background="Transparent">



    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">



        <Grid Margin="20,20,20,140">



            <StackPanel MaxWidth="1200" HorizontalAlignment="Stretch">



                



                <StackPanel Margin="0,0,0,30" HorizontalAlignment="Center">



                    <StackPanel Margin="0,0,0,15" HorizontalAlignment="Center">



                        <TextBlock Text="Wszystkie subskrypcje" Foreground="{DynamicResource TextPrimary}" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>



                        <TextBlock Text="Zarządzaj swoimi cyklicznymi płatnościami" Foreground="{DynamicResource TextSecondary}" FontSize="14" Margin="0,5,0,0" HorizontalAlignment="Center" TextAlignment="Center"/>



                    </StackPanel>



                    <Button Style="{StaticResource SuccessButton}" Command="{Binding OpenAddSubscriptionDialogCommand}" VerticalAlignment="Center" HorizontalAlignment="Center">



                        <StackPanel Orientation="Horizontal">



                            <TextBlock Text="+" Margin="0,0,8,0" FontWeight="Bold" FontSize="16"/>



                            <TextBlock Text="Dodaj nową" FontWeight="SemiBold" FontSize="14"/>



                        </StackPanel>



                    </Button>



                </StackPanel>



                <Border Style="{StaticResource CardStyle}">



                    <StackPanel>






                        <WrapPanel Margin="0,0,0,25">






                            <Border Background="{DynamicResource InputBackground}" CornerRadius="6" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" Padding="15,10" Width="260" Margin="0,0,15,10">



                                <Grid>



                                    <Grid.ColumnDefinitions>



                                        <ColumnDefinition Width="Auto"/>



                                        <ColumnDefinition Width="*"/>



                                    </Grid.ColumnDefinitions>



                                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource PrimaryBrush}" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>



                                    <TextBlock x:Name="SearchPlaceholder" Grid.Column="1" Text="Szukaj subskrypcji..." Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" IsHitTestVisible="False">



                                        <TextBlock.Style>



                                            <Style TargetType="TextBlock">



                                                <Setter Property="Visibility" Value="Collapsed"/>



                                                <Style.Triggers>



                                                    <DataTrigger Binding="{Binding Text.Length, ElementName=SearchTextBox}" Value="0">



                                                        <Setter Property="Visibility" Value="Visible"/>



                                                    </DataTrigger>



                                                </Style.Triggers>



                                            </Style>



                                        </TextBlock.Style>



                                    </TextBlock>



                                    <TextBox x:Name="SearchTextBox" Grid.Column="1" Background="Transparent" Foreground="{DynamicResource TextPrimary}" BorderThickness="0" VerticalAlignment="Center" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" CaretBrush="{DynamicResource TextPrimary}"/>



                                </Grid>



                            </Border>






                            <ComboBox Style="{StaticResource ModernComboBox}"



                                      ItemsSource="{Binding FilterCategories}" 



                                      SelectedItem="{Binding SelectedCategory}" 



                                      DisplayMemberPath="Name" 



                                      Width="180" 



                                      Height="38" 



                                      Margin="0,0,15,10" 



                                      VerticalContentAlignment="Center" 



                                      Background="{DynamicResource InputBackground}" 



                                      Foreground="{DynamicResource TextPrimary}" 



                                      BorderBrush="{DynamicResource CardBorder}" />






                            <ComboBox Style="{StaticResource ModernComboBox}"



                                      ItemsSource="{Binding StatusOptions}" 



                                      SelectedItem="{Binding SelectedStatus}" 



                                      Width="140" 



                                      Height="38" 



                                      Margin="0,0,15,10" 



                                      VerticalContentAlignment="Center" 



                                      Background="{DynamicResource InputBackground}" 



                                      Foreground="{DynamicResource TextPrimary}" 



                                      BorderBrush="{DynamicResource CardBorder}" />






                            <ComboBox Style="{StaticResource ModernComboBox}"



                                      ItemsSource="{Binding SortOptions}" 



                                      SelectedItem="{Binding SelectedSortOption}" 



                                      Width="210" 



                                      Height="38" 



                                      Margin="0,0,0,10" 



                                      VerticalContentAlignment="Center" 



                                      Background="{DynamicResource InputBackground}" 



                                      Foreground="{DynamicResource TextPrimary}" 



                                      BorderBrush="{DynamicResource CardBorder}" />



                        </WrapPanel>






                        <Grid Margin="60,0,15,15">

                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="1.8*"/>

                                <ColumnDefinition Width="0.8*" />

                                <ColumnDefinition Width="0.8*" />

                                <ColumnDefinition Width="2.3*" />

                                <ColumnDefinition Width="Auto" MinWidth="80"/>

                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Nazwa usługi" Foreground="{DynamicResource TextSecondary}" FontSize="13" FontWeight="SemiBold"/>

                            <TextBlock Grid.Column="1" Text="Cykl rozliczeniowy" Foreground="{DynamicResource TextSecondary}" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Left"/>

                            <TextBlock Grid.Column="2" Text="Status" Foreground="{DynamicResource TextSecondary}" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Left" Margin="10,0,0,0"/>

                            <TextBlock Grid.Column="3" Text="Cena" Foreground="{DynamicResource TextSecondary}" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,30,0"/>

                            <TextBlock Grid.Column="4" Text="Akcje" Foreground="{DynamicResource TextSecondary}" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,15,0"/>

                        </Grid>



                        <Rectangle Height="1" Fill="{DynamicResource CardBorder}" Margin="0,0,0,15"/>






                        <ItemsControl x:Name="SubscriptionsList" ItemsSource="{Binding DisplayedSubscriptions}">



                            <ItemsControl.ItemTemplate>



                                <DataTemplate>



                                    <StackPanel>






                                        <Button Command="{Binding ToggleExpandCommand}" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch" Cursor="Hand">



                                            <Button.Template>



                                                <ControlTemplate TargetType="Button">



                                                    <Border CornerRadius="8" Padding="15,10" Background="Transparent" x:Name="rowBorder">



                                                        <Grid>

                                                            <Grid.ColumnDefinitions>

                                                                <ColumnDefinition Width="Auto"/>

                                                                <ColumnDefinition Width="1.8*"/>

                                                                <ColumnDefinition Width="0.8*" />

                                                                <ColumnDefinition Width="0.8*" />

                                                                <ColumnDefinition Width="2.3*" />

                                                                <ColumnDefinition Width="Auto" MinWidth="80"/>

                                                            </Grid.ColumnDefinitions>

                                                            <Border Width="45" Height="45" CornerRadius="10" Background="{Binding IconColor}" Margin="0,0,15,0">

                                                                <TextBlock Text="{Binding Initials}" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                                            </Border>

                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,10,0">
                                                                 <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold" FontSize="15" TextTrimming="CharacterEllipsis"/>
                                                                 <TextBlock Text="{Binding Category}" Foreground="{DynamicResource TextSecondary}" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                                             </StackPanel>

                                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">

                                                                <TextBlock Text="{Binding Cycle}" Foreground="{DynamicResource TextPrimary}" FontSize="14" VerticalAlignment="Center"/>

                                                            </StackPanel>

                                                            


                                                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">

                                                                <Ellipse Width="8" Height="8" Fill="{Binding StatusBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>

                                                                <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource TextPrimary}" FontSize="14" VerticalAlignment="Center" FontWeight="Medium"/>

                                                            </StackPanel>

                                                            


                                                            <TextBlock Grid.Column="4" Text="{Binding FormattedPrice}" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,30,0"/>



                                                            <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">



                                                                <Button Command="{Binding DataContext.EditSubscriptionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Edytuj" Margin="0,0,15,0">



                                                                    <Button.Template>



                                                                        <ControlTemplate TargetType="Button">



                                                                            <TextBlock x:Name="btnTxt" Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource TextSecondary}" FontSize="14" VerticalAlignment="Center"/>



                                                                            <ControlTemplate.Triggers>



                                                                                <Trigger Property="IsMouseOver" Value="True">



                                                                                    <Setter TargetName="btnTxt" Property="Foreground" Value="{StaticResource PrimaryBrush}"/>



                                                                                </Trigger>



                                                                            </ControlTemplate.Triggers>



                                                                        </ControlTemplate>



                                                                    </Button.Template>



                                                                </Button>



                                                                <Button Command="{Binding DataContext.DeleteSubscriptionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Usuń">



                                                                    <Button.Template>



                                                                        <ControlTemplate TargetType="Button">



                                                                            <TextBlock x:Name="btnTxt" Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource TextSecondary}" FontSize="14" VerticalAlignment="Center"/>



                                                                            <ControlTemplate.Triggers>



                                                                                <Trigger Property="IsMouseOver" Value="True">



                                                                                    <Setter TargetName="btnTxt" Property="Foreground" Value="{StaticResource DangerBrush}"/>



                                                                                </Trigger>



                                                                            </ControlTemplate.Triggers>



                                                                        </ControlTemplate>



                                                                    </Button.Template>



                                                                </Button>



                                                            </StackPanel>



                                                        </Grid>



                                                    </Border>



                                                    <ControlTemplate.Triggers>



                                                        <Trigger Property="IsMouseOver" Value="True">



                                                            <Setter TargetName="rowBorder" Property="Background" Value="#2A2A35" />



                                                        </Trigger>



                                                    </ControlTemplate.Triggers>



                                                </ControlTemplate>



                                            </Button.Template>



                                        </Button>






                                        <Border x:Name="detailsBorder" 



                                                Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"



                                                Background="#14141A" 



                                                BorderBrush="{DynamicResource CardBorder}" 



                                                BorderThickness="1" 



                                                CornerRadius="10" 



                                                Padding="20,15" 



                                                Margin="60,5,15,10">



                                            <Grid>



                                                <Grid.ColumnDefinitions>



                                                    <ColumnDefinition Width="1.5*"/>



                                                    <ColumnDefinition Width="1*"/>



                                                </Grid.ColumnDefinitions>






                                                <StackPanel Grid.Column="0">



                                                    <TextBlock Text="OKRES AKTYWNOŚCI" Foreground="{DynamicResource TextSecondary}" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>



                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">



                                                        <TextBlock Text="Rozpoczęto: " Foreground="{DynamicResource TextSecondary}" FontSize="13"/>



                                                        <TextBlock Text="{Binding StartDateFormatted}" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold" FontSize="13" Margin="0,0,15,0"/>



                                                        <TextBlock Text="Następna płatność: " Foreground="{DynamicResource TextSecondary}" FontSize="13"/>



                                                        <TextBlock Text="{Binding NextPaymentDateFormatted}" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold" FontSize="13"/>



                                                    </StackPanel>



                                                    <TextBlock Text="STATUS SUBSKRYPCJI" Foreground="{DynamicResource TextSecondary}" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>



                                                    <StackPanel Orientation="Horizontal">



                                                        <Border Background="{Binding StatusBrush}" CornerRadius="4" Padding="8,4" Margin="0,0,15,0" VerticalAlignment="Center">



                                                            <TextBlock Text="{Binding StatusText}" Foreground="White" FontWeight="Bold" FontSize="11"/>



                                                        </Border>



                                                        <Button Command="{Binding ToggleStatusCommand}" Style="{StaticResource OutlineButton}" Padding="10,5" Content="Przełącz aktywność" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>



                                                        <Button Command="{Binding LogPaymentCommand}" Style="{StaticResource SuccessButton}" Padding="12,5" Content="✓ Zarejestruj płatność" FontSize="12" VerticalAlignment="Center"/>



                                                    </StackPanel>



                                                    <StackPanel Visibility="{Binding IsShared, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,15,0,0">
                                                        <TextBlock Text="WSPÓŁDZIELENIE KOSZTÓW" Foreground="{DynamicResource TextSecondary}" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                                                        <WrapPanel>
                                                            <TextBlock Text="Subskrypcja współdzielona z " Foreground="{DynamicResource TextSecondary}" FontSize="13" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding SharedWith}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" FontSize="13" VerticalAlignment="Center"/>
                                                            <TextBlock Text=" (łącznie " Foreground="{DynamicResource TextSecondary}" FontSize="13" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding NumberOfMembers}" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="13" VerticalAlignment="Center"/>
                                                            <TextBlock Text=" os.). Twój koszt: " Foreground="{DynamicResource TextSecondary}" FontSize="13" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding SplitPrice, StringFormat={}{0:0.00}}" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" FontSize="13" VerticalAlignment="Center"/>
                                                            <TextBlock Text=" PLN / os. (pełna kwota: " Foreground="{DynamicResource TextSecondary}" FontSize="13" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Model.Price, StringFormat={}{0:0.00}}" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="13" VerticalAlignment="Center"/>
                                                            <TextBlock Text=" PLN)." Foreground="{DynamicResource TextSecondary}" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                            <Button Command="{Binding DataContext.EditSubscriptionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource OutlineButton}" Padding="10,4" Content="⚙️ Zarządzaj współdzieleniem" FontSize="11" VerticalAlignment="Center"/>
                                                        </WrapPanel>
                                                    </StackPanel>

                                                    <StackPanel Margin="0,15,0,0">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsShared}" Value="False">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <TextBlock Text="WSPÓŁDZIELENIE KOSZTÓW" Foreground="{DynamicResource TextSecondary}" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="Ta subskrypcja nie jest współdzielona." Foreground="{DynamicResource TextSecondary}" FontSize="13" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                                            <Button Command="{Binding DataContext.EditSubscriptionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource SuccessButton}" Padding="12,5" Content="🔗 Udostępnij rodzinie i podziel koszty" FontSize="12" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </StackPanel>



                                                </StackPanel>






                                                <StackPanel Grid.Column="1" Margin="20,0,0,0">



                                                    <TextBlock Text="DODATKOWE NOTATKI" Foreground="{DynamicResource TextSecondary}" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>



                                                    <Border Background="#1A1A22" CornerRadius="6" Padding="2" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" MinHeight="60">



                                                        <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}" 



                                                                 Foreground="{DynamicResource TextPrimary}" 



                                                                 Background="Transparent" 



                                                                 BorderThickness="0" 



                                                                 AcceptsReturn="True" 



                                                                 TextWrapping="Wrap" 



                                                                 FontSize="13"



                                                                 CaretBrush="{DynamicResource TextPrimary}"



                                                                 VerticalScrollBarVisibility="Auto"



                                                                 Padding="8,6"/>



                                                    </Border>



                                                    <Button Content="Zapisz notatkę" 



                                                            Command="{Binding SaveNoteCommand}" 



                                                            Style="{StaticResource PrimaryButton}" 



                                                            Height="28" 



                                                            Padding="12,0" 



                                                            FontSize="11" 



                                                            HorizontalAlignment="Right" 



                                                            Margin="0,8,0,0"/>



                                                </StackPanel>



                                            </Grid>



                                        </Border>



                                        <Rectangle Height="1" Fill="{DynamicResource CardBorder}" Margin="0,5,0,10"/>



                                    </StackPanel>



                                </DataTemplate>



                            </ItemsControl.ItemTemplate>



                        </ItemsControl>



                    </StackPanel>



                </Border>



            </StackPanel>



        </Grid>



    </ScrollViewer>



</UserControl>