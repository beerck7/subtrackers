<UserControl x:Class="SubscriptionTracker.SubscriptionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20,20,20,90">
            <StackPanel MaxWidth="1000" HorizontalAlignment="Center">
                
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource PrimaryBrush}" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="SubTrack" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <WrapPanel Margin="0,0,0,30">
                    <StackPanel Margin="0,0,20,15">
                        <TextBlock Text="Wszystkie subskrypcje" Foreground="{StaticResource TextPrimary}" FontSize="36" FontWeight="Bold"/>
                        <TextBlock Text="Zarządzaj swoimi cyklicznymi płatnościami" Foreground="{StaticResource TextSecondary}" FontSize="14" Margin="0,5,0,0"/>
                    </StackPanel>
                    <Button Style="{StaticResource SuccessButton}" Command="{Binding OpenAddSubscriptionDialogCommand}" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+" Margin="0,0,8,0" FontWeight="Bold" FontSize="16"/>
                            <TextBlock Text="Dodaj nową" FontWeight="SemiBold" FontSize="14"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        
                        <!-- Szukaj -->
                        <Border Background="{StaticResource InputBackground}" CornerRadius="6" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Padding="15,10" Margin="0,0,0,25">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource PrimaryBrush}" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="SearchPlaceholder" Grid.Column="1" Text="Szukaj subskrypcji po nazwie..." Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text.Length, ElementName=SearchTextBox}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBox x:Name="SearchTextBox" Grid.Column="1" Background="Transparent" Foreground="{StaticResource TextPrimary}" BorderThickness="0" VerticalAlignment="Center" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" CaretBrush="{StaticResource TextPrimary}"/>
                            </Grid>
                        </Border>

                        <!-- Nagłówki tabeli -->
                        <Grid Margin="60,0,15,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="Auto" MinWidth="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Nazwa usługi" Foreground="{StaticResource TextSecondary}" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="Cykl rozliczeniowy" Foreground="{StaticResource TextSecondary}" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Column="2" Text="Cena" Foreground="{StaticResource TextSecondary}" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,30,0"/>
                            <TextBlock Grid.Column="3" Text="Akcje" Foreground="{StaticResource TextSecondary}" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,15,0"/>
                        </Grid>

                        <Rectangle Height="1" Fill="{StaticResource CardBorder}" Margin="0,0,0,15"/>

                        <!-- LISTA OBSŁUGIWANA PRZEZ MODEL Z DANYMI -->
                        <ItemsControl x:Name="SubscriptionsList" ItemsSource="{Binding DisplayedSubscriptions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <Border CornerRadius="8" Padding="15,10" Background="Transparent" x:Name="rowBorder">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="1.5*" />
                                                    <ColumnDefinition Width="1*" />
                                                    <ColumnDefinition Width="Auto" MinWidth="80"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="45" Height="45" CornerRadius="10" Background="{Binding IconColor}" Margin="0,0,15,0">
                                                    <TextBlock Text="{Binding Initials}" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="15"/>
                                                    <TextBlock Text="{Binding Category}" Foreground="{StaticResource TextSecondary}" FontSize="13"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{Binding Cycle}" Foreground="{StaticResource TextPrimary}" FontSize="14" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="3" Text="{Binding FormattedPrice}" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,30,0"/>
                                                
                                                <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <Button Command="{Binding DataContext.EditSubscriptionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Edytuj" Margin="0,0,15,0">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <TextBlock x:Name="btnTxt" Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource TextSecondary}" FontSize="14" VerticalAlignment="Center"/>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="btnTxt" Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                    <Button Command="{Binding DataContext.DeleteSubscriptionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Usuń">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <TextBlock x:Name="btnTxt" Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource TextSecondary}" FontSize="14" VerticalAlignment="Center"/>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="btnTxt" Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <Rectangle Height="1" Fill="{StaticResource CardBorder}" Margin="0,5,0,10"/>
                                    </StackPanel>
                                    <DataTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="rowBorder" Property="Background" Value="#2A2A35" />
                                        </Trigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>