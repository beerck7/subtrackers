<UserControl x:Class="SubscriptionTracker.SubscriptionsView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#1B1B2B">

        <StackPanel Margin="20">

            <TextBlock Text="Wszystkie subskrypcje"
                       Foreground="White"
                       FontSize="26"
                       FontWeight="Bold"/>

            <!-- SEARCH -->
            <TextBox Margin="0,20,0,10"
                     Background="#24243A"
                     Foreground="White"
                     Padding="10"
                     Text="Szukaj..."/>

            <!-- LISTA -->
            <ListView>
                <ListViewItem Content="Netflix - 60 PLN"/>
                <ListViewItem Content="Spotify - 19,99 PLN"/>
                <ListViewItem Content="Adobe - 249 PLN"/>
            </ListView>

        </StackPanel>
    </Grid>
</UserControl>