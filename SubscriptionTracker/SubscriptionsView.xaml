<UserControl x:Class="SubscriptionTracker.SubscriptionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="50,40,50,0">
        <StackPanel>
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" Foreground="#3b82f6" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="SubTrack" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <Grid Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Wszystkie subskrypcje" Foreground="White" FontSize="32" FontWeight="SemiBold"/>
                    <TextBlock Text="Zarządzaj swoimi cyklicznymi płatnościami" Foreground="#8A8A93" FontSize="13" Margin="0,5,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Background="#22c55e" Foreground="White" BorderThickness="0" Cursor="Hand" Click="AddNewButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="20,10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+" Margin="0,0,5,0" FontWeight="Bold"/>
                        <TextBlock Text="Dodaj nową" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Border Background="#1E1E24" CornerRadius="12" Padding="25" BorderBrush="#2A2A35" BorderThickness="1">
                <StackPanel>
                    
                    <!-- Szukaj -->
                    <Border Background="#16161B" CornerRadius="6" BorderBrush="#33333F" BorderThickness="1" Padding="15,10" Margin="0,0,0,25">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" Foreground="#3b82f6" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="SearchPlaceholder" Grid.Column="1" Text="Szukaj subskrypcji po nazwie..." Foreground="#5A5A65" VerticalAlignment="Center" IsHitTestVisible="False"/>
                            <TextBox x:Name="SearchTextBox" Grid.Column="1" Background="Transparent" Foreground="White" BorderThickness="0" VerticalAlignment="Center" TextChanged="SearchTextBox_TextChanged" CaretBrush="White"/>
                        </Grid>
                    </Border>

                    <!-- Nagłówki tabeli -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Nazwa usługi" Foreground="#8A8A93" FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="Cykl rozliczeniowy" Foreground="#8A8A93" FontSize="12" HorizontalAlignment="Left"/>
                        <TextBlock Grid.Column="2" Text="Cena" Foreground="#8A8A93" FontSize="12" HorizontalAlignment="Right"/>
                    </Grid>

                    <Rectangle Height="1" Fill="#2A2A35" Margin="0,0,0,15"/>

                    <!-- LISTA OBSŁUGIWANA PRZEZ MODEL Z DANYMI -->
                    <ItemsControl x:Name="SubscriptionsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="150"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="40" Height="40" CornerRadius="8" Background="{Binding IconColor}" Margin="0,0,15,0">
                                            <TextBlock Text="{Binding Initials}" Foreground="White" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                                            <TextBlock Text="{Binding Category}" Foreground="#8A8A93" FontSize="12"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding Cycle}" Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding FormattedPrice}" Foreground="White" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Rectangle Height="1" Fill="#2A2A35" Margin="0,5,0,15"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </Border>

        </StackPanel>
    </Grid>
</UserControl>