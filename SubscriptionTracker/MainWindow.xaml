<Window x:Class="SubscriptionTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SubTrack" Height="780" Width="1050"
        Background="#0F0F12"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">
    <Window.Resources>
        <!-- Style for Bottom Navigation Buttons -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#808080"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <ContentControl x:Name="MainContent" Margin="0,0,0,0" />

        <!-- DOLNE MENU (Floating) -->
        <Border VerticalAlignment="Bottom" HorizontalAlignment="Center"
                Background="#1E1E24"
                CornerRadius="30"
                Margin="0,0,0,30"
                Padding="25,12"
                Width="480"
                BorderBrush="#2A2A35"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Panel główny -->
                <Button Grid.Column="0" ToolTip="Panel główny" Style="{StaticResource NavButton}" Foreground="#3b82f6" Click="ShowDashboard">
                    <StackPanel>
                        <TextBlock Text="&#xE80A;" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="Panel główny" FontSize="10" HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Subskrypcje -->
                <Button Grid.Column="1" ToolTip="Subskrypcje" Style="{StaticResource NavButton}" Click="ShowSubscriptions">
                    <StackPanel>
                        <TextBlock Text="&#xE8C7;" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="Subskrypcje" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Kategorie -->
                <Button Grid.Column="2" ToolTip="Kategorie" Style="{StaticResource NavButton}" Click="ShowCategories">
                    <StackPanel>
                        <TextBlock Text="&#xE8EC;" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="Kategorie" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Ustawienia -->
                <Button Grid.Column="3" ToolTip="Ustawienia" Style="{StaticResource NavButton}" Click="ShowSettings">
                    <StackPanel>
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="Ustawienia" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Separator -->
                <Rectangle Grid.Column="4" Width="1" Fill="#33333F" Margin="10,5"/>

                <!-- Wyloguj -->
                <Button Grid.Column="5" ToolTip="Wyloguj" Style="{StaticResource NavButton}">
                    <StackPanel>
                        <TextBlock Text="&#xE8D8;" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="Wyloguj" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </Grid>
        </Border>
    </Grid>
</Window>
