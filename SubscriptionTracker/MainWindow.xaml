<Window x:Class="SubscriptionTracker.MainWindow"
	   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	   xmlns:local="clr-namespace:SubscriptionTracker"
	   Title="SubTrack" Height="700" Width="1100"
	   Background="#0F0F1A"
	   WindowStartupLocation="CenterScreen">
	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="*"/>
			<RowDefinition Height="80"/>
		</Grid.RowDefinitions>

		<!-- GŁÓWNA KARTA -->
		<ContentControl x:Name="MainContent" />

		<!-- DOLNE MENU -->
		<Border Grid.Row="1"
				Background="#24243A"
				CornerRadius="30"
				Margin="200,10"
				Padding="10">

			<UniformGrid Columns="5">

				<Button Content="🏠" FontSize="20" ToolTip="Panel główny" Foreground="White" Background="Transparent" BorderThickness="0" Click="ShowDashboard"/>
				<Button Content="📋" FontSize="20" ToolTip="Subskrypcje" Foreground="Gray" Background="Transparent" BorderThickness="0" Click="ShowSubscriptions"/>
				<Button Content="🏷" FontSize="20" ToolTip="Kategorie" Foreground="Gray" Background="Transparent" BorderThickness="0" Click="ShowCategories"/>
				<Button Content="⚙" FontSize="20" ToolTip="Ustawienia" Foreground="Gray" Background="Transparent" BorderThickness="0" Click="ShowSettings"/>
				<Button Content="🚪" FontSize="20" ToolTip="Wyloguj" Foreground="Gray" Background="Transparent" BorderThickness="0" />

			</UniformGrid>
		</Border>
	</Grid>
</Window>
