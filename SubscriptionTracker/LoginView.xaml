<UserControl x:Class="SubscriptionTracker.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SubscriptionTracker"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900"
             Background="{DynamicResource AppBackground}">

    <UserControl.Resources>
        <!-- Custom stylized PasswordBox mimicking the ModernTextBox -->
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource InputBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Background Glowing Ambient Gradients -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="500" Height="500" CornerRadius="250" Margin="0,0,150,150" Opacity="0.12" IsHitTestVisible="False">
            <Border.Background>
                <RadialGradientBrush Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                    <GradientStop Color="#3b82f6" Offset="0" />
                    <GradientStop Color="Transparent" Offset="1" />
                </RadialGradientBrush>
            </Border.Background>
        </Border>
        <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="500" Height="500" CornerRadius="250" Margin="150,150,0,0" Opacity="0.08" IsHitTestVisible="False">
            <Border.Background>
                <RadialGradientBrush Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                    <GradientStop Color="#a855f7" Offset="0" />
                    <GradientStop Color="Transparent" Offset="1" />
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <!-- Main Authentication Card -->
        <Border Style="{DynamicResource CardStyle}" 
                Width="390" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center" 
                CornerRadius="16" 
                Padding="30,35">
            
            <StackPanel>
                <!-- Logo -->
                <TextBlock Text="&#xE8C7;" 
                           FontFamily="Segoe MDL2 Assets" 
                           FontSize="48" 
                           Foreground="{DynamicResource PrimaryBrush}" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,12" />

                <!-- App title -->
                <TextBlock Text="SubTrack" 
                           FontSize="26" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource TextPrimary}" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,4" />

                <TextBlock Text="Zarządzaj swoimi subskrypcjami" 
                           FontSize="13" 
                           Foreground="{DynamicResource TextSecondary}" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,25" />

                <!-- Card header title -->

                <!-- Inputs -->
                <StackPanel Margin="0,0,0,15">
                    <!-- Username -->
                    <TextBlock Text="Nazwa użytkownika" 
                               FontSize="11" 
                               FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextSecondary}" 
                               Margin="0,0,0,6" />
                    <TextBox x:Name="UsernameInput" 
                             Style="{DynamicResource ModernTextBox}" 
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                             Height="38" 
                             VerticalContentAlignment="Center" 
                             Padding="10,0" 
                             Margin="0,0,0,12" />

                    <!-- Email (Visible only in Register Mode) -->
                    <StackPanel Visibility="{Binding IsRegisterMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Adres e-mail" 
                                   FontSize="11" 
                                   FontWeight="SemiBold" 
                                   Foreground="{DynamicResource TextSecondary}" 
                                   Margin="0,0,0,6" />
                        <TextBox Style="{DynamicResource ModernTextBox}" 
                                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="38" 
                                 VerticalContentAlignment="Center" 
                                 Padding="10,0" 
                                 Margin="0,0,0,12" />
                    </StackPanel>

                    <!-- Password -->
                    <TextBlock Text="Hasło" 
                               FontSize="11" 
                               FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextSecondary}" 
                               Margin="0,0,0,6" />
                    <PasswordBox x:Name="PasswordInput" 
                                 Style="{StaticResource ModernPasswordBox}" 
                                 Height="38" 
                                 VerticalContentAlignment="Center" 
                                 Padding="10,0" 
                                 Margin="0,0,0,15" />
                </StackPanel>

                <!-- Dynamic Error / Status Messages with zero converter required -->
                <TextBlock x:Name="ErrorText"
                           Text="{Binding ErrorMessage}" 
                           FontSize="12" 
                           TextWrapping="Wrap" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,15">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </Trigger>
                                <Trigger Property="Text" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding IsStatusError}" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Action Button -->
                <Button Style="{DynamicResource PrimaryButton}" 
                        Content="{Binding SubmitButtonText}" 
                        Height="40" 
                        Click="SubmitButton_Click" 
                        Margin="0,0,0,15" />

                <!-- Dynamic Toggle Button -->
                <Button Style="{DynamicResource NavButton}" 
                        Content="{Binding ToggleText}" 
                        FontSize="12" 
                        Command="{Binding ToggleModeCommand}" 
                        HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
