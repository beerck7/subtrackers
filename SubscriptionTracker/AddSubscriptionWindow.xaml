<Window x:Class="SubscriptionTracker.AddSubscriptionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dodaj subskrypcję" Height="500" Width="400"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        FontFamily="Segoe UI">
    <Border BorderBrush="#33333F" BorderThickness="1" CornerRadius="12" Background="#1E1E24" Padding="25">
        <StackPanel>
            <Grid Margin="0,0,0,30">
                <TextBlock Text="Dodaj nową subskrypcję" Foreground="White" FontSize="20" FontWeight="Bold"/>
                <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" Foreground="Gray" Background="Transparent" BorderThickness="0" HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="Hand" Click="CloseButton_Click"/>
            </Grid>
            
            <TextBlock Text="Nazwa usługi (np. Spotify)" Foreground="#8A8A93" FontSize="12" Margin="0,0,0,5"/>
            <TextBox x:Name="NameTextBox" Background="#16161B" Foreground="White" BorderBrush="#33333F" BorderThickness="1" Padding="10" Margin="0,0,0,20" Text=""/>

            <TextBlock Text="Kategoria" Foreground="#8A8A93" FontSize="12" Margin="0,0,0,5"/>
            <ComboBox x:Name="CategoryComboBox" Padding="10" Margin="0,0,0,20">
                <ComboBoxItem Content="Streaming" IsSelected="True"/>
                <ComboBoxItem Content="Oprogramowanie"/>
                <ComboBoxItem Content="Gry"/>
                <ComboBoxItem Content="Inne"/>
            </ComboBox>

            <TextBlock Text="Cykl rozliczeniowy" Foreground="#8A8A93" FontSize="12" Margin="0,0,0,5"/>
            <ComboBox x:Name="CycleComboBox" Padding="10" Margin="0,0,0,20">
                <ComboBoxItem Content="Miesięcznie" IsSelected="True"/>
                <ComboBoxItem Content="Rocznie"/>
            </ComboBox>

            <TextBlock Text="Cena (PLN)" Foreground="#8A8A93" FontSize="12" Margin="0,0,0,5"/>
            <TextBox x:Name="PriceTextBox" Background="#16161B" Foreground="White" BorderBrush="#33333F" BorderThickness="1" Padding="10" Margin="0,0,0,30" Text="0.00"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>
                <Button Content="Anuluj" Background="#16161B" Foreground="White" BorderBrush="#33333F" BorderThickness="1" Padding="10" Cursor="Hand" Click="CancelButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Grid.Column="2" Content="Dodaj subskrypcję" Background="#22c55e" Foreground="White" BorderThickness="0" Padding="10" FontWeight="Bold" Cursor="Hand" Click="AddButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</Window>
