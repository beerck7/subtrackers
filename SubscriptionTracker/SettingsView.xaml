<UserControl x:Class="SubscriptionTracker.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Background" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="border" Width="44" Height="24" CornerRadius="12" Background="{TemplateBinding Background}">
                            <Ellipse x:Name="thumb" Width="18" Height="18" Fill="White" HorizontalAlignment="Left" Margin="3,0,0,0">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="thumbTransform" X="0" />
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryBrush}" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="thumbTransform" Storyboard.TargetProperty="X" To="20" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="thumbTransform" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20,20,20,90">
            <StackPanel MaxWidth="1000" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource PrimaryBrush}" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="SubTrack" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Margin="0,0,0,30">
                    <TextBlock Text="Ustawienia" Foreground="{StaticResource TextPrimary}" FontSize="36" FontWeight="Bold"/>
                    <TextBlock Text="Preferencje aplikacji i konfiguracja konta" Foreground="{StaticResource TextSecondary}" FontSize="14" Margin="0,5,0,0"/>
                </StackPanel>

                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Profil użytkownika" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="18" Margin="0,0,0,20"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Alex Developer" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="18"/>
                                <TextBlock Text="alex@example.com" Foreground="{StaticResource TextSecondary}" FontSize="14" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Edytuj" Style="{StaticResource OutlineButton}" Width="100"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Preferencje" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="18" Margin="0,0,0,20"/>
                        
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Ciemny motyw" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="15"/>
                                <TextBlock Text="Wygląd aplikacji" Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="0,4,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>
                        
                        <Rectangle Height="1" Fill="{StaticResource CardBorder}" Margin="0,15,0,20"/>
                        
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Powiadomienia" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="15"/>
                                <TextBlock Text="Alerty o nadchodzących płatnościach" Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="0,4,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" IsChecked="True" VerticalAlignment="Center"/>
                        </Grid>

                        <Rectangle Height="1" Fill="{StaticResource CardBorder}" Margin="0,15,0,20"/>

                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Waluta domyślna" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="PLN (zł)" Foreground="{StaticResource TextSecondary}" FontSize="15" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Button Content="Usuń dane konta" Style="{StaticResource DangerButton}" Margin="0,30,0,0" Padding="0,15" />
                
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>