<UserControl x:Class="SubscriptionTracker.FamilyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:SubscriptionTracker"
             mc:Ignorable="d"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20,20,20,110">
            <StackPanel MaxWidth="1200" HorizontalAlignment="Stretch">

                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource PrimaryBrush}" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="SubTrack Social" Foreground="{DynamicResource TextPrimary}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,25">
                    <TextBlock Text="Rodzina i współdzielenie" Foreground="{DynamicResource TextPrimary}" FontSize="36" FontWeight="Bold"/>
                    <TextBlock Text="Wyszukuj innych użytkowników systemu po nazwie lub e-mailu, wysyłaj zaproszenia i wspólnie śledźcie koszty." Foreground="{DynamicResource TextSecondary}" FontSize="14" Margin="0,5,0,0"/>
                </StackPanel>

                <Border Style="{StaticResource CardStyle}" CornerRadius="16" Margin="0,0,0,25" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Wyszukaj użytkowników w systemie" Foreground="{DynamicResource TextPrimary}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" Height="45" Margin="0,0,12,0"
                                     Style="{StaticResource ModernTextBox}"
                                     Tag="Wpisz nazwę użytkownika lub adres e-mail..."
                                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>

                            <Button Grid.Column="1" Content="Szukaj" Width="120" Height="45"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding SearchCommand}" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding SearchResults}" Margin="0,15,0,0">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchResults.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="360" Margin="0,0,12,12" Background="#1C1C22" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="12" Padding="12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource PrimaryBrush}" Margin="0,0,12,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Initials}" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Username}" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Email}" Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                                            </StackPanel>

                                            <Button Grid.Column="2" 
                                                    Command="{Binding DataContext.SendInvitationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" 
                                                    IsEnabled="{Binding CanSend}"
                                                    Padding="12,6" Height="32" FontSize="11" FontWeight="SemiBold">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource SuccessButton}">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <TextBlock Text="{Binding StatusText}"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <StackPanel Margin="0,0,0,25">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PendingReceived.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Otrzymane zaproszenia do rodziny" Foreground="{DynamicResource TextPrimary}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <ItemsControl ItemsSource="{Binding PendingReceived}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="380" Margin="0,0,16,12" Background="#1B221B" BorderBrush="#2e422e" BorderThickness="1" CornerRadius="12" Padding="15">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="#2e7d32" Margin="0,0,12,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Initials}" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimary}" FontSize="15" FontWeight="Bold"/>
                                            <TextBlock Text="Chce dołączyć do Twojej rodziny" Foreground="#81c784" FontSize="11"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="Akceptuj" 
                                                    Command="{Binding DataContext.AcceptInvitationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" 
                                                    Style="{StaticResource SuccessButton}" 
                                                    Padding="12,6" Height="32" Margin="0,0,8,0" FontSize="11" />
                                            <Button Content="Odrzuć" 
                                                    Command="{Binding DataContext.DeclineOrRemoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" 
                                                    Style="{StaticResource OutlineButton}" 
                                                    Padding="12,6" Height="32" FontSize="11" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel Margin="0,0,0,25">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PendingSent.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Wysłane zaproszenia (oczekujące)" Foreground="{DynamicResource TextPrimary}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <ItemsControl ItemsSource="{Binding PendingSent}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="380" Margin="0,0,16,12" Background="#221C1C" BorderBrush="#422e2e" BorderThickness="1" CornerRadius="12" Padding="15">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="#c62828" Margin="0,0,12,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Initials}" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimary}" FontSize="15" FontWeight="Bold"/>
                                            <TextBlock Text="Czeka na akceptację" Foreground="#ef9a9a" FontSize="11"/>
                                        </StackPanel>

                                        <Button Grid.Column="2" Content="Anuluj" 
                                                Command="{Binding DataContext.DeclineOrRemoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}" 
                                                Style="{StaticResource OutlineButton}" 
                                                Padding="12,6" Height="32" FontSize="11" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <TextBlock Text="Twoja Rodzina" Foreground="{DynamicResource TextPrimary}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,15"/>

                <Border CornerRadius="16" Background="#14141A" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" Padding="30" Margin="0,0,0,30">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Members.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource TextSecondary}" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Brak połączonych członków" Foreground="{DynamicResource TextPrimary}" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Wyszukaj drugiego użytkownika powyżej i wyślij mu zaproszenie, aby wspólnie rozliczać subskrypcje!" Foreground="{DynamicResource TextSecondary}" FontSize="13" HorizontalAlignment="Center" Margin="0,5,0,0" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding Members}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="380" Margin="0,0,16,16" CornerRadius="16" Padding="15">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#25252D"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Width="48" Height="48" CornerRadius="24" Margin="0,0,15,0" VerticalAlignment="Center" Background="{Binding AvatarColor}">
                                        <TextBlock Text="{Binding Initials}" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimary}" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            
                                            <Border CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource PrimaryBrush}" Padding="6,2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Relationship}" Foreground="{DynamicResource PrimaryBrush}" FontSize="10" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>

                                        <TextBlock Text="{Binding SharedSubscriptionsCountText}" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding TotalShareAmountText}" Foreground="{StaticResource SuccessBrush}" FontSize="13" FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <Button Grid.Column="2" Command="{Binding DataContext.DeclineOrRemoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Rozłącz (usuń z rodziny)" VerticalAlignment="Center">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <TextBlock x:Name="btnTxt" Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource TextSecondary}" FontSize="14" VerticalAlignment="Center"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <TextBlock.Foreground>
                                                            <SolidColorBrush Color="#ef4444"/>
                                                        </TextBlock.Foreground>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
