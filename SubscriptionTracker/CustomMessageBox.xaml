<Window x:Class="SubscriptionTracker.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SubTrack Alert" 
        Height="Auto" 
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True">
    
    <Window.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeIn}"/>
        </EventTrigger>
    </Window.Triggers>

    <Border BorderBrush="{DynamicResource CardBorder}" 
            BorderThickness="1" 
            CornerRadius="16" 
            Background="{DynamicResource CardBackground}" 
            Padding="24"
            Margin="15">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="25" Opacity="0.4" ShadowDepth="5" Direction="270"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- NAGŁÓWEK (DRAGGABLE) -->
            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="Header_MouseLeftButtonDown" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="TxtTitle" 
                           Text="Komunikat" 
                           Foreground="{DynamicResource TextPrimary}" 
                           FontSize="16" 
                           FontWeight="Bold"/>
                
                <Button Grid.Column="1" 
                        Click="BtnClose_Click" 
                        Background="Transparent" 
                        BorderThickness="0" 
                        Cursor="Hand" 
                        VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock Text="&#xE10A;" 
                                       FontFamily="Segoe MDL2 Assets" 
                                       Foreground="{DynamicResource TextSecondary}" 
                                       FontSize="12" />
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- TREŚĆ -->
            <Grid Grid.Row="1" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- IKONA -->
                <TextBlock x:Name="TxtIcon" 
                           Grid.Column="0" 
                           Text="&#xE9CE;" 
                           FontFamily="Segoe MDL2 Assets" 
                           FontSize="32" 
                           Foreground="{DynamicResource PrimaryBrush}" 
                           VerticalAlignment="Top" 
                           Margin="0,0,16,0"/>

                <!-- TEKST WIADOMOŚCI -->
                <TextBlock x:Name="TxtMessage" 
                           Grid.Column="1" 
                           Text="Treść wiadomości..." 
                           Foreground="{DynamicResource TextPrimary}" 
                           FontSize="14" 
                           TextWrapping="Wrap" 
                           LineHeight="20"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- PRZYCISKI AKCJI -->
            <StackPanel Grid.Row="2" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right">
                
                <Button x:Name="BtnNo" 
                        Content="Nie" 
                        Width="100" 
                        Height="36" 
                        Margin="0,0,12,0"
                        Style="{StaticResource OutlineButton}" 
                        Click="BtnNo_Click"
                        Visibility="Collapsed"/>
                
                <Button x:Name="BtnYes" 
                        Content="Tak" 
                        Width="100" 
                        Height="36" 
                        Margin="0,0,12,0"
                        Style="{StaticResource PrimaryButton}" 
                        Click="BtnYes_Click"
                        Visibility="Collapsed"/>
                
                <Button x:Name="BtnOk" 
                        Content="OK" 
                        Width="100" 
                        Height="36" 
                        Style="{StaticResource PrimaryButton}" 
                        Click="BtnOk_Click"
                        Visibility="Visible"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
